# AetherOS Hybrid — local-first agent OS (Pocket Realm)
# Ignore generated runtime state + secrets + cache.

# Runtime state (generated, not source)
*.json
!fleet.json            # fleet.json IS source (generated by fleet_router --emit, committed as schema ref)
command_inbox.json
agent_activity.json
credit_status.json
state.json
quests.json
theme_request.json

# Python cache
__pycache__/
*.pyc

# Secrets — NEVER commit. Keys live in ~/.hermes/.env
.env
*.env
.env.*

# Legacy / archived pre-merge builds
legacy/

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store

# stray artifacts dropped into dir by other tools
_foundry_big.py
_foundry_mid.py
_record.py
_shot.py
foundry.py
recap.html
recap.png

# generated works index
works.json
